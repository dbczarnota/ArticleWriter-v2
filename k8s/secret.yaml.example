# EXAMPLE ONLY — nie commituj prawdziwych wartości!
# Prawdziwe wartości ustaw jako GitHub Secrets i wygeneruj przez deploy.yml.
apiVersion: v1
kind: Secret
metadata:
  name: headlinesforge-secrets
  namespace: headlinesforge
type: Opaque
stringData:
  DATABASE_URL: "postgresql+asyncpg://articlewriter:CHANGE_ME@postgres:5432/articlewriter"
  POSTGRES_PASSWORD: "CHANGE_ME"
  GEMINI_API_KEY: ""
  OPENAI_API_KEY: ""
  GROQ_API_KEY: ""
  OPENROUTER_API_KEY: ""
  SERPER_API_KEY: ""
  JINA_API_KEY: ""
  KINDE_DOMAIN: ""
  KINDE_AUDIENCE: ""
  LOGFIRE_TOKEN: ""
