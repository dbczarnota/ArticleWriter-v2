# Copy to .env and fill values. Never commit .env.

# === LLM / scraping APIs ===
SERPER_API_KEY=
GEMINI_API_KEY=
JINA_API_KEY=

# === Logfire (optional; set send_to_logfire="if-token-present" honors empty string as "off") ===
LOGFIRE_TOKEN=

# === Postgres (used when DB_BACKEND=postgres) ===
# POSTGRES_PASSWORD goes into docker-compose.yml's `db` service init.
# DATABASE_URL is what the application connects to.
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql+asyncpg://articlewriter:changeme@localhost:5432/articlewriter

# === Backend switches (defaults below = run.py works without Docker / Kinde / DB) ===
# DB_BACKEND=null         # or 'postgres' to write to the DB
# AUTH_BACKEND=null       # or 'kinde' to require JWT bearer

# === Kinde (used when AUTH_BACKEND=kinde) ===
# KINDE_DOMAIN=
# KINDE_AUDIENCE=
# KINDE_M2M_CLIENT_ID=
# KINDE_M2M_CLIENT_SECRET=
